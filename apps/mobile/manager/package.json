{
  "name": "@billdesk/manager-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082",
    "dev": "expo start --port 8082",
    "start:go": "expo start --go --port 8082 -c",
    "start:go:tunnel": "expo start --go --tunnel --port 8082 -c",
    "start:dev-client": "expo start --dev-client --port 8082 -c",
    "start:dev-client:tunnel": "expo start --dev-client --tunnel --port 8082 -c",
    "android": "expo run:android --port 8082",
    "android:build": "expo run:android",
    "android:build:clean": "expo run:android --no-build-cache",
    "manger-pro": "bash ./scripts/manager-pro.sh",
    "manager-pro": "bash ./scripts/manager-pro.sh",
    "android:go": "expo start --go --android --port 8082 -c",
    "android:dev": "expo start --dev-client --android --port 8082 -c",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082"
  },
  "dependencies": {
