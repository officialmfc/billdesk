{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../auth",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["functions/**/*.ts", "../auth/lib/**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
