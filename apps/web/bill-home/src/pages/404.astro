---
import PortalLayout from "../layouts/PortalLayout.astro";
---

<PortalLayout title="Not Found - Bill Home" description="The requested bill-home page was not found.">
  <section class="hero">
    <div class="hero-main">
      <div class="tag"><span class="dot"></span>404</div>
      <h2>Page not found</h2>
      <p class="lead">Use the launcher or the release registry to get back to a valid route.</p>
      <div class="hero-actions">
        <a class="button primary" href="/">Go home</a>
        <a class="button ghost" href="/releases">Open releases</a>
      </div>
    </div>
  </section>
</PortalLayout>
