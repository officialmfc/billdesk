# Sentry Configuration
# Get your DSN from https://sentry.io/settings/projects/

# Client-side Sentry DSN (public, used in browser)
NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@o123456.ingest.sentry.io/123456

# Server-side Sentry DSN (private, used in Node.js)
SENTRY_DSN=https://your-private-key@o123456.ingest.sentry.io/123456

# Optional: Environment name (defaults to NODE_ENV)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Optional: Traces sample rate (0.0 to 1.0, default: 0.1)
# Lower values save quota. 0.1 = 10% of transactions
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: Auth token for uploading source maps (required for production builds)
# Get from https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN=your-auth-token-here

# Optional: Release identifier (auto-generated from git if not set)
# NEXT_PUBLIC_SENTRY_RELEASE=my-app@1.0.0

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Other Environment Variables
NODE_ENV=development
