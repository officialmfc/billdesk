{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "noEmit": true,
    "incremental": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "worker.ts",
    "lib/**/*.ts",
    "d1/**/*.ts",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "app/**/*.tsx",
    "components/**/*.tsx",
    "instrumentation*.ts",
    "sentry*.ts",
    "next.config.ts",
    "open-next.config.ts"
  ]
}
