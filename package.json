{
  "name": "mfc-billdesk-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MFC BillDesk - Modular Monorepo with Shared Packages",
  "scripts": {
    "dead-code-check": "dead-code-checker -f ./packages ./apps ./libs",
    "dev": "turbo run dev",
    "dev:auth": "turbo run dev --filter=@mfc/auth-hub",
    "dev:auth:policy": "turbo run dev --filter=@mfc/auth-policy",
    "dev:web:manager": "turbo run dev --filter=@mfc/web-manager",
    "dev:web:user": "pnpm --dir apps/web/user dev",
    "dev:web:bill-home": "pnpm --dir apps/web/bill-home dev",
    "dev:web:manager:debug": "pnpm --dir apps/web/manager devdebug",
    "dev:web:manager:alt": "pnpm --dir apps/web/manager devalt",
    "dev:web:manager:altdebug": "pnpm --dir apps/web/manager devaltdebug",
    "dev:desktop:manager": "turbo run dev --filter=@mfc/desktop-manager",
    "install:mobile:manager": "pnpm --dir apps/mobile/manager install",
    "install:mobile:admin": "pnpm --dir apps/mobile/admin install",
    "install:mobile:user": "pnpm --dir apps/mobile/user install",
    "dev:mobile:manager": "pnpm --dir apps/mobile/manager dev",
    "dev:mobile:manager:go": "pnpm --dir apps/mobile/manager start:go",
    "dev:mobile:manager:android": "pnpm --dir apps/mobile/manager android:dev",
    "dev:mobile:manager:ios": "pnpm --dir apps/mobile/manager ios",
    "dev:mobile:admin": "pnpm --dir apps/mobile/admin dev",
    "dev:mobile:admin:android": "pnpm --dir apps/mobile/admin android:dev",
    "dev:mobile:user": "pnpm --dir apps/mobile/user dev",
    "dev:mobile:user:android": "pnpm --dir apps/mobile/user android:dev",
    "start": "turbo run start",
    "start:web:manager": "turbo run build --filter=@mfc/web-manager && turbo run start --filter=@mfc/web-manager",
    "start:mobile:manager": "pnpm --dir apps/mobile/manager start",
    "build": "node scripts/build-root.mjs",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:auth": "turbo run build --filter=@mfc/auth-hub",
    "build:auth:ui": "turbo run build --filter=@mfc/auth-ui",
    "build:auth:policy": "turbo run build --filter=@mfc/auth-policy",
    "deploy:auth": "pnpm --dir apps/auth deploy && pnpm --dir apps/auth-policy deploy && pnpm --dir apps/auth-ui deploy",
    "check:cloudflare:auth": "node scripts/check-cloudflare-auth.mjs",
    "sync:auth:secrets": "node scripts/sync-auth-cloudflare-secrets.mjs",
    "sync:releases:cors": "node scripts/sync-release-r2-cors.mjs",
    "build:web": "turbo run build --filter=@mfc/web-manager",
    "build:web:manager": "turbo run build --filter=@mfc/web-manager",
    "build:web:user": "pnpm --dir apps/web/user build",
    "build:web:bill-home": "pnpm --dir apps/web/bill-home build",
    "build:desktop:manager": "turbo run build --filter=@mfc/desktop-manager",
    "build:mobile": "pnpm --dir apps/mobile/manager exec tsc --noEmit",
    "build:mobile:manager": "pnpm --dir apps/mobile/manager exec tsc --noEmit",
    "build:mobile:admin": "pnpm --dir apps/mobile/admin exec tsc --noEmit",
    "build:mobile:user": "pnpm --dir apps/mobile/user exec tsc --noEmit",
    "clean": "turbo run clean",
    "clean:cache": "rm -rf .turbo node_modules/.cache apps/*/.next apps/*/.turbo",
    "reset:dev": "pnpm clean:cache && echo '✅ Dev cache cleared! Close browser tabs, unregister Service Worker, then restart dev server.'",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "type-check:auth": "pnpm --dir apps/auth type-check",
    "type-check:auth:ui": "pnpm --dir apps/auth-ui type-check",
    "type-check:auth:policy": "pnpm --dir apps/auth-policy type-check",
    "type-check:web:manager": "pnpm --dir apps/web/manager type-check",
    "type-check:web:user": "pnpm --dir apps/web/user type-check",
    "type-check:web:bill-home": "pnpm --dir apps/web/bill-home check",
    "type-check:desktop:manager": "pnpm --dir apps/desktop/manager type-check",
    "type-check:mobile:manager": "pnpm --dir apps/mobile/manager exec tsc --noEmit",
    "type-check:mobile:admin": "pnpm --dir apps/mobile/admin exec tsc --noEmit",
    "type-check:mobile:user": "pnpm --dir apps/mobile/user exec tsc --noEmit",
    "seed": "node db/seed-data.js",
    "seed:users": "node db/seed-users-sales.js",
    "seed:sales": "node db/seed-sales-only.js",
    "seed:reset": "node db/reset-and-seed.js",
    "seed:complete": "node db/complete-seed.js",
    "help": "echo \"dev, dev:web:manager, dev:web:user, dev:web:bill-home, dev:web:manager:debug, dev:web:manager:alt, dev:desktop:manager, dev:mobile:manager, dev:mobile:manager:go, dev:mobile:manager:android, dev:mobile:admin, dev:mobile:admin:android, dev:mobile:user, dev:mobile:user:android, start, start:web:manager, start:mobile:manager, build, build:web:manager, build:web:user, build:web:bill-home, build:desktop:manager, build:mobile:manager, build:mobile:admin, build:mobile:user, type-check, type-check:web:manager, type-check:web:user, type-check:web:bill-home, type-check:desktop:manager, type-check:mobile:manager, type-check:mobile:admin, type-check:mobile:user, clean, seed, seed:users, seed:sales, seed:reset, seed:complete\""
  },
  "dependencies": {
    "@faker-js/faker": "^10.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@sentry/nextjs": "^10.27.0",
    "@supabase/supabase-js": "^2.80.0",
    "dotenv": "^17.2.3",
    "expo": "~55.0.11",
    "metro-runtime": "~0.83.3",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "devDependencies": {
    "dead-code-checker": "^1.1.0",
    "supabase": "^2.54.11",
    "turbo": "^2.6.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ],
    "overrides": {
      "@types/react": "19.2.3",
      "@types/react-dom": "19.2.3"
    },
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40",
  "keywords": [
    "monorepo",
    "billing",
    "inventory",
    "offline-first"
  ],
  "author": "MFC BillDesk Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
